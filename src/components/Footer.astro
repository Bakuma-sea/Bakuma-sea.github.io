---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border flex flex-col gap-3 border-t py-6 sm:flex-row sm:items-center sm:justify-between sm:py-5"
  >
    <div class="flex flex-col">
      <span class="text-lg font-semibold">Bakuma Notes</span>
      <span class="text-muted-foreground text-sm">
        记录 RL、LLM 后训练与阅读笔记的长期索引。
      </span>
    </div>
    <div class="flex flex-col items-start whitespace-nowrap text-sm sm:items-end">
      <Socials />
      <span class="mt-2">{t.footer.copyright} &#169; {currentYear}</span>
      <span>{t.footer.allRightsReserved}</span>
    </div>
  </div>
</footer>
