---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  category: string;
  categoryName: string;
  count?: number;
};

const { category, categoryName, count } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `categories/${category}/`)}
    class="category-tile group flex flex-col justify-between gap-4"
  >
    <span
      class="text-muted-foreground text-[0.68rem] font-semibold tracking-[0.16em] uppercase"
    >
      分类
    </span>
    <span class="group-hover:text-accent text-lg font-semibold"
      >{categoryName}</span
    >
    {
      count !== undefined && (
        <span class="text-muted-foreground text-sm">{count} 篇</span>
      )
    }
  </a>
</li>
