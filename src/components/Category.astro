---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  category: string;
  categoryName: string;
  count?: number;
};

const { category, categoryName, count } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `categories/${category}/`)}
    class="paper-panel group flex items-center justify-between gap-4 px-5 py-4 transition-transform hover:-translate-y-0.5"
  >
    <span class="group-hover:text-accent font-semibold">{categoryName}</span>
    {
      count !== undefined && (
        <span class="text-muted-foreground text-sm">{count} 篇</span>
      )
    }
  </a>
</li>
