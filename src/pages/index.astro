---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getTagCounts } from "@/utils/getTagCounts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { readingList } from "@/data/readingList";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts
  .filter(({ data }) => data.featured)
  .slice(0, 3);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const tagStats = getTagCounts(sortedPosts).slice(0, 8);
const latestReading = readingList.slice(0, 4);
const archiveYears = new Set(
  sortedPosts.map(post => post.data.pubDatetime.getFullYear())
).size;
const heroFeature = featuredPosts[0] ?? sortedPosts[0];
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section
      id="hero"
      class="grid gap-10 py-10 lg:grid-cols-[minmax(0,0.88fr)_minmax(32rem,1.12fr)] lg:items-start lg:gap-14 xl:py-14"
    >
      <div class="min-w-0">
        <p class="editorial-kicker">
          Reinforcement Learning / LLM Post-Training / Reading Notes
        </p>
        <div class="mt-4 flex items-end gap-3">
          <h1
            class="max-w-[11em] text-[3.15rem] leading-[1.08] font-bold sm:text-[4.8rem] lg:max-w-[9.6em]"
          >
            为训练与阅读留下可复用的索引
          </h1>
          <a
            target="_blank"
            href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
            class="mb-4 inline-flex shrink-0"
            aria-label="RSS Feed"
            title="RSS Feed"
          >
            <IconRss
              width={22}
              height={22}
              class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>

        <p class="mt-6 max-w-[34em] text-lg leading-8">
          这里主要记录我在 <strong>RL、LLM 训练</strong> 以及相关论文阅读中的结构化笔记，
          让训练链路、实现细节和阅读心得都能被反复回查。
        </p>

        <div class="section-rule mt-8 grid gap-5 pt-5 sm:grid-cols-4">
          <div>
            <p class="text-muted-foreground text-sm">文章总数</p>
            <p class="mt-2 text-4xl font-semibold">{sortedPosts.length}</p>
          </div>
          <div>
            <p class="text-muted-foreground text-sm">归档年份</p>
            <p class="mt-2 text-4xl font-semibold">{archiveYears}</p>
          </div>
          <div>
            <p class="text-muted-foreground text-sm">清单条目</p>
            <p class="mt-2 text-4xl font-semibold">{readingList.length}</p>
          </div>
          <div>
            <p class="text-muted-foreground text-sm">{t.home.socialLinks}</p>
            <div class="mt-3">
              <Socials />
            </div>
          </div>
        </div>
      </div>

      {
        heroFeature && (
          <article class="paper-panel overflow-hidden">
            <div class="grid min-h-[24rem] gap-0 md:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]">
              <div class="flex flex-col justify-between p-7 md:p-9">
                <div>
                  <p class="editorial-kicker">精选文章</p>
                  <h2 class="mt-8 max-w-[14em] text-3xl leading-[1.22] font-semibold sm:text-4xl">
                    {heroFeature.data.title}
                  </h2>
                  <p class="text-muted-foreground mt-6 text-sm">
                    {heroFeature.data.pubDatetime
                      .toLocaleDateString("zh-CN")
                      .replaceAll("/", ".")}
                  </p>
                  <p class="mt-5 max-w-[42ch] text-base leading-8">
                    {heroFeature.data.description}
                  </p>
                </div>
                <a
                  href={getRelativeLocaleUrl(
                    locale,
                    `posts/${heroFeature.id}/`
                  )}
                  class="editorial-link mt-8"
                >
                  阅读全文
                  <IconArrowRight class="inline-block rtl:-rotate-180" />
                </a>
              </div>
              <div class="quiet-panel m-4 min-h-[16rem] overflow-hidden md:m-5">
                <div class="grid h-full content-between gap-6 p-6">
                  <div class="section-rule pt-5">
                    <p class="text-muted-foreground text-sm">主题</p>
                    <p class="mt-2 text-2xl font-semibold">RL / LLM / Agent</p>
                  </div>
                  <div class="grid grid-cols-2 gap-3 text-sm">
                    <div class="border-border rounded-2xl border p-4">
                      <p class="text-muted-foreground">索引方式</p>
                      <p class="mt-2 font-semibold">标签 + 归档</p>
                    </div>
                    <div class="border-border rounded-2xl border p-4">
                      <p class="text-muted-foreground">主要用途</p>
                      <p class="mt-2 font-semibold">跨设备查阅</p>
                    </div>
                  </div>
                  <div class="h-24 rounded-[1.5rem] bg-[linear-gradient(135deg,var(--accent),transparent_62%),radial-gradient(circle_at_20%_20%,rgb(255_255_255_/_0.34),transparent_35%)] opacity-80" />
                </div>
              </div>
            </div>
          </article>
        )
      }
    </section>

    {
      featuredPosts.length > 1 && (
        <section id="featured" class="section-rule pt-12">
          <div class="grid gap-6 lg:grid-cols-[20rem_minmax(0,1fr)] lg:gap-12">
            <div>
              <p class="editorial-kicker">{t.home.featured}</p>
              <p class="mt-4 text-base leading-7">
                作为首页入口，我更希望精选文章像目录页的前言，而不是普通文章列表。
              </p>
            </div>
            <ul class="divide-y divide-[color:var(--border)]">
              {featuredPosts.slice(1).map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <section
      id="middle-grid"
      class="section-rule grid gap-10 py-12 lg:grid-cols-[minmax(0,1.25fr)_minmax(21rem,0.75fr)] lg:gap-12"
    >
      <div class="min-w-0">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="editorial-kicker">专题索引</p>
            <h2 class="mt-4 text-3xl font-semibold">
              用标签追踪主题，而不是只追时间。
            </h2>
          </div>
        </div>
        <ul class="mt-8 flex flex-wrap gap-3">
          {
            tagStats.map(({ tag, tagName, count }) => (
              <li>
                <a
                  href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
                  class="paper-panel inline-flex items-center gap-2 px-4 py-2 text-sm transition-transform hover:-translate-y-0.5"
                >
                  <span>#{tagName}</span>
                  <span class="text-muted-foreground text-xs">{count}</span>
                </a>
              </li>
            ))
          }
        </ul>

        <div class="section-rule mt-10 pt-8">
          <div class="flex items-end justify-between gap-4">
            <div>
              <p class="editorial-kicker">{t.home.recentPosts}</p>
              <h2 class="mt-4 text-3xl font-semibold">最近写下的笔记</h2>
            </div>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "posts")}
              class="editorial-link whitespace-nowrap"
            >
              查看全部
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
          <ul class="mt-6 divide-y divide-[color:var(--border)]">
            {
              recentPosts
                .slice(0, postsConfig.perIndex)
                .map(data => <Card variant="h3" {...data} />)
            }
          </ul>
        </div>
      </div>

      <aside class="quiet-panel p-6 lg:p-8">
        <div class="pt-8 lg:pt-0">
          <p class="editorial-kicker">归档与入口</p>
          <div class="mt-5 space-y-6">
            <a href={getRelativeLocaleUrl(locale, "archives")} class="block">
              <h3 class="text-2xl font-semibold">归档</h3>
              <p class="mt-2 leading-7">
                按年份回看写作轨迹，更适合做阶段性复盘。
              </p>
            </a>
            <a href={getRelativeLocaleUrl(locale, "search")} class="block">
              <h3 class="text-2xl font-semibold">搜索</h3>
              <p class="mt-2 leading-7">
                查术语、论文名或训练方法时，搜索永远比翻页更快。
              </p>
            </a>
            <a
              href={getRelativeLocaleUrl(locale, "reading-list")}
              class="block"
            >
              <h3 class="text-2xl font-semibold">阅读清单</h3>
              <p class="mt-2 leading-7">
                把在读、计划读和已读材料放在一个长期维护的清单里。
              </p>
            </a>
            <a href={getRelativeLocaleUrl(locale, "submit-note")} class="block">
              <h3 class="text-2xl font-semibold">发布笔记</h3>
              <p class="mt-2 leading-7">
                在其他设备上通过 GitHub Issue 粘贴 Markdown，自动发布到博客。
              </p>
            </a>
          </div>
        </div>
      </aside>
    </section>

    <section id="reading-list" class="section-rule py-12">
      <div class="grid gap-8 lg:grid-cols-[20rem_minmax(0,1fr)] lg:gap-12">
        <div>
          <p class="editorial-kicker">阅读清单</p>
          <h2 class="mt-4 text-3xl font-semibold">
            把书、论文和技术报告放在同一张桌面上。
          </h2>
          <p class="mt-4 leading-7">
            当前清单偏向 RL、偏好优化、推理模型和后训练工程，适合持续补充。
          </p>
          <LinkButton
            href={getRelativeLocaleUrl(locale, "reading-list")}
            class="editorial-link mt-8 whitespace-nowrap"
          >
            进入清单
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
        <ul class="grid gap-4 md:grid-cols-2">
          {
            latestReading.map(item => (
              <li class="paper-panel px-5 py-5">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="text-xl leading-8 font-semibold">
                      {item.title}
                    </h3>
                    <p class="text-muted-foreground mt-1 text-sm">
                      {item.author} · {item.kind}
                    </p>
                  </div>
                  <span class="text-accent text-sm whitespace-nowrap">
                    {item.status}
                  </span>
                </div>
                <p class="mt-4 text-sm leading-7">{item.note}</p>
                <p class="text-muted-foreground mt-4 text-xs tracking-[0.12em] uppercase">
                  {item.topic}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
